# Copia este archivo a ".streamlit/secrets.toml" (mismo folder) para local,
# o pega su contenido en "Settings > Secrets" en Streamlit Community Cloud.
# NUNCA subas tu "secrets.toml" real a git (agrégalo a .gitignore).

API_URL = "https://script.google.com/macros/s/PON-AQUI-TU-DEPLOYMENT-ID/exec"
SETUP_KEY = "PON-AQUI-LA-CLAVE-DE-MANTENIMIENTO"
